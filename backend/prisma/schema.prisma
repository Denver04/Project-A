generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phoneNumber  String   @unique
  password     String
  role         String   @default("USER")
  createdAt    String 
  updatedAt    String
}